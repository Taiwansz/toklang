{
  "name": "toklang",
  "version": "1.0.0",
  "description": "Motor de compressão de prompts para IA — menos tokens, mesma qualidade",
  "main": "dist/server.js",
  "scripts": {
    "dev:cli": "ts-node src/cli.ts",
    "dev:web": "ts-node src/server.ts",
    "build": "tsc",
    "start:cli": "node dist/cli.js",
    "start:web": "node dist/server.js",
    "start": "npm run start:web"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "chalk": "^4.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
